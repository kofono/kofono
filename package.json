{
    "name": "kofono-monorepo",
    "private": true,
    "sideEffects": false,
    "type": "module",
    "scripts": {
        "build": "turbo run build",
        "build:watch": "turbo run build:watch",
        "clean": "turbo run clean",
        "dev": "turbo run dev",
        "dev:doc": "turbo run doc",
        "check": "turbo run check",
        "check:fix": "turbo run check:fix",
        "check:fix:core": "turbo run check:fix --filter kofono",
        "format": "turbo run format",
        "prepublish": "turbo run prepublish",
        "test:core": "turbo run test --filter kofono --ui tui",
        "turbo:clean": "turbo daemon clean"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.15",
        "turbo": "2.9.12"
    },
    "engines": {
        "node": ">=22",
        "pnpm": ">=10"
    },
    "packageManager": "pnpm@11.1.2",
    "volta": {
        "node": "25.9.0",
        "pnpm": "11.1.2"
    }
}

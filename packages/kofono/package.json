{
    "name": "kofono",
    "version": "0.9.0",
    "description": "Headless Form Engine Library",
    "keywords": [
        "form",
        "headless",
        "json",
        "schema",
        "validation",
        "typescript"
    ],
    "author": "Francois Lajoie",
    "license": "Apache-2.0",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+ssh://git@github.com:kofono/kofono.git",
        "directory": "packages/kofono"
    },
    "files": ["dist", "README.md", "LICENSE.md"],
    "scripts": {
        "build": "tsdown --config tsdown.config.ts",
        "build:watch": "pnpm build --watch",
        "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
        "coverage": "vitest run --coverage",
        "check": "pnpm biome check",
        "check:fix": "pnpm check --write",
        "test": "vitest",
        "prepublish": "pnpm check:fix && pnpm build"
    },
    "dependencies": {},
    "devDependencies": {
        "@types/node": "^25.7.0",
        "@vitest/coverage-v8": "^4.1.6",
        "tsdown": "^0.22.0",
        "tslib": "^2.8.1",
        "typescript": "^6.0.3",
        "vitest": "^4.1.6"
    },
    "engines": {
        "node": ">=22",
        "pnpm": ">=11.0.0"
    }
}

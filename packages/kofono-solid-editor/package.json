{
    "name": "@kofono/solid-editor",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "source": "./src/index.ts",
    "module": "./dist/index.js",
    "files": ["dist", "src"],
    "scripts": {
        "build": "tsdown --config tsdown.config.ts",
        "build:watch": "tsdown --config tsdown.config.ts --watch",
        "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
        "editor": "vite serve dev",
        "format": "pnpm dlx @biomejs/biome format",
        "preview": "vite preview"
    },
    "dependencies": {
        "ace-builds": "^1.43.6",
        "class-variance-authority": "0.7.1",
        "clsx": "2.1.1",
        "solid-js": "^1.9.12"
    },
    "peerDependencies": {
        "solid-js": "^1.9.12",
        "tailwindcss": "^4.2.0"
    },
    "devDependencies": {
        "@solidjs/testing-library": "^0.8.10",
        "@tailwindcss/postcss": "^4.2.4",
        "@tailwindcss/vite": "^4.2.4",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/user-event": "^14.6.1",
        "jsdom": "^29.0.2",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.4",
        "tailwindcss-animate": "^1.0.7",
        "tsdown": "^0.22.0",
        "unplugin-solid": "^1.0.0",
        "vite": "^8.0.10",
        "vite-plugin-solid": "^2.11.12",
        "vitest": "^4.1.4"
    },
    "typesVersions": {},
    "engines": {
        "node": ">=20",
        "pnpm": ">=11.0.0"
    },

    "browser": {}
}
